# Environment: "production" or "development"
# In development: COOKIE_SECURE is automatically set to false (allows HTTP)
APP_ENV=production

# HuggingFace Configuration
# Get your token from https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_TIMEOUT=30

# LLM Retry Configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1

# LLM Generation Config
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.01

# API Config
# List of allowed origins for CORS. e.g. ["http://localhost:3000", "https://yourfrontend.com"]
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
REQUEST_TIMEOUT_SECONDS=120

# Database (Azure SQL / SQL Server via aioodbc + ODBC Driver for SQL Server)
# Local Docker (use ODBC Driver 17 or 18, whichever you have installed):
DATABASE_URL=mssql+aioodbc://sa:YourPassword123!@localhost:1433/nlpdf_db?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
# Azure SQL (production - ODBC Driver 18 recommended):
# DATABASE_URL=mssql+aioodbc://<user>:<password>@<server>.database.windows.net:1433/<db>?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# JWT Authentication
# IMPORTANT: Change this in production! Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-use-secrets-token
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie Domain
# Set to your domain in production (e.g. ".example.com" for cross-subdomain cookies).
# Leave empty for host-only cookies (backend and frontend on same domain).
COOKIE_DOMAIN=

# Email Provider Configuration
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=YourApp <noreply@yourdomain.com>

# Cloudflare Turnstile (CAPTCHA)
# Get keys at dash.cloudflare.com → Turnstile → Add site
# Site key is public (hardcoded in frontend). Only the secret key goes here.
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key